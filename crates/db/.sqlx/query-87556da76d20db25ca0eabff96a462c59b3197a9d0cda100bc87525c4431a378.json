  "query": "\n        SELECT\n            fill_id,\n            maker_id,\n            taker_id,\n            maker_order_id,\n            taker_order_id,\n            price,\n            quantity,\n            maker_position as \"maker_position!: SideType\",\n            taker_position as \"taker_position!: SideType\",\n            created_at\n        FROM fills\n        WHERE maker_id=$1 OR taker_id=$1\n        ORDER BY created_at DESC\n        ",
